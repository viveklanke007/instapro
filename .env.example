# -----------------------------------------------------------------------------
# InstaPro - Production Environment Configuration Blueprint
# -----------------------------------------------------------------------------
# Rename this file to '.env' in your deployment or hosting environment and fill
# out the variables below.
# -----------------------------------------------------------------------------

# [REQUIRED] Node.js Environment
# Determines whether the server mounts live-reload development services or
# serves compiled, highly optimized static client-side production assets.
# Choices: "production", "development"
NODE_ENV="production"

# [REQUIRED] Google Gemini API Key
# Enables the advanced, fully integrated AI assistant tools inside InstaPro,
# including AI-Powered Captions, Smart Hashtag Generation, Profile branding reviews,
# Content Niche Strategy suggestions, and Intelligent Real-time Comment Moderation.
# Get yours here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIzaSy..."

# [OPTIONAL] Application Host URL
# Self-referential URL used for linking assets, webhooks, or generating correct
# callbacks. In Google AI Studio Build, this is auto-injected.
# Example: "https://your-custom-domain.com"
APP_URL="http://localhost:3000"

# [OPTIONAL] Process Running Port
# The port the full-stack server listens on. Defaults internally to 3000.
PORT=3000
